---
// HeroSection — landing page header with author photo, name, positioning statement, CTA
// Photo is a placeholder until a real image is supplied in /public/images/
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__photo-wrap">
      <div class="hero__photo-placeholder" aria-hidden="true">DS</div>
    </div>

    <div class="hero__content">
      <p class="hero__eyebrow">Daniel Sykes</p>
      <h1 class="hero__headline">
        Patterns, trade-offs, and real-world experience at the intersection of
        <span class="hero__accent">AI, architecture, and systems design.</span>
      </h1>
      <p class="hero__sub">
        Senior AI and systems architect. Writing about the decisions that actually matter —
        at scale, under constraint, with real consequences.
      </p>
      <a href="/blog" class="hero__cta">Read the blog</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 1.5rem 4rem;
    background-color: var(--color-surface);
  }

  .hero__inner {
    max-width: 56rem;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
  }

  /* ── Author photo ── */
  .hero__photo-wrap {
    flex-shrink: 0;
  }

  .hero__photo-placeholder {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.02em;
    /* Halo effect */
    box-shadow:
      0 0 0 4px var(--color-surface),
      0 0 0 6px var(--color-primary);
  }

  /* ── Copy ── */
  .hero__eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin: 0 0 0.75rem;
  }

  .hero__headline {
    font-size: clamp(1.625rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    letter-spacing: -0.02em;
  }

  .hero__accent {
    color: var(--color-primary);
  }

  .hero__sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 2rem;
    max-width: 44rem;
  }

  /* ── CTA button ── */
  .hero__cta {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background-color: var(--color-primary);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background-color 0.15s ease, transform 0.1s ease;
    letter-spacing: 0.01em;
  }

  .hero__cta:hover {
    background-color: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .hero__cta:active {
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .hero__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.5rem;
    }

    .hero__sub {
      margin-inline: auto;
    }
  }
</style>
