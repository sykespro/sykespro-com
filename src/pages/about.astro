---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_GITHUB, SOCIAL_LINKEDIN } from '../consts';
---

<BaseLayout
  title="About"
  description="Daniel Sykes — senior AI and systems architect. About his work, background, and approach."
>
  <div class="about">
    <header class="about__header">
      <h1 class="about__title">About</h1>
    </header>

    <div class="about__body">

      <section class="about__section">
        <h2 class="about__section-title">Work</h2>
        <p>
          <!-- [TODO: replace with real bio — current role / org] -->
          I'm a senior AI and systems architect working at the intersection of language model
          integration, distributed systems design, and engineering leadership.
        </p>
        <p>
          <!-- [TODO: replace with specific current focus areas / recent projects] -->
          My current focus is on the architectural patterns and organisational structures that
          make AI integration sustainable at scale — not the prototype stage, but the years after.
        </p>
      </section>

      <section class="about__section">
        <h2 class="about__section-title">Background</h2>
        <p>
          <!-- [TODO: replace with real background — years of experience, key roles, notable orgs] -->
          I've spent the last decade designing and building systems that need to be right under
          pressure — high-stakes, high-scale, with real consequences for failure. That experience
          shapes how I think about architecture: every decision is a trade-off, and the trade-offs
          that matter are the ones you don't see until production.
        </p>
      </section>

      <section class="about__section">
        <h2 class="about__section-title">This site</h2>
        <p>
          The blog is the primary thing here. I write about AI architecture, systems thinking,
          and the leadership and organisational dimensions of technical work. The audience is
          practitioners — people who have to make these decisions for real, not people learning
          the concepts for the first time.
        </p>
        <p>
          I don't write tutorials. I write about decisions, trade-offs, and the patterns that
          recur across enough systems that they're worth naming.
        </p>
      </section>

      <section class="about__section">
        <h2 class="about__section-title">Advisory work</h2>
        <p>
          <!-- [TODO: replace with specific advisory terms / availability] -->
          I take a small number of advisory engagements each year with engineering teams
          navigating hard architectural decisions — particularly in AI integration and systems
          design. If that sounds relevant,{' '}
          <a href="/contact">get in touch</a>.
        </p>
      </section>

      <section class="about__section about__links">
        <h2 class="about__section-title">Find me</h2>
        <ul class="about__link-list">
          <li>
            <a href={SOCIAL_LINKEDIN} target="_blank" rel="noopener noreferrer">
              LinkedIn
            </a>
          </li>
          <li>
            <a href={SOCIAL_GITHUB} target="_blank" rel="noopener noreferrer">
              GitHub
            </a>
          </li>
        </ul>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .about__header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .about__title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .about__body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .about__section-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin: 0 0 0.875rem;
  }

  .about__section p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .about__section p:last-child {
    margin-bottom: 0;
  }

  .about__section a {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: rgba(67, 56, 202, 0.4);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }

  .about__section a:hover {
    text-decoration-color: var(--color-primary);
  }

  .about__link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
  }

  .about__link-list a {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .about__link-list a:hover {
    color: var(--color-primary-hover);
  }
</style>
