---
import ContactForm from '../components/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Daniel Sykes — for consulting, advisory work, or conversation about AI architecture and systems design."
>
  <div class="contact-page">
    <header class="contact-page__header">
      <h1 class="contact-page__title">Get in touch</h1>
      <p class="contact-page__sub">
        For consulting and advisory engagements, collaboration, or conversation.
        I read everything and respond to messages that are specific about what
        you're working on.
      </p>
    </header>

    <ContactForm />
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 40rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .contact-page__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-page__title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.03em;
    margin: 0 0 0.875rem;
  }

  .contact-page__sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
