---
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const PAGE_SIZE = 10;
const page1Posts = posts.slice(0, PAGE_SIZE);
const hasMore = posts.length > PAGE_SIZE;
---

<BaseLayout
  title="Blog"
  description="Writing on AI architecture, systems thinking, and the decisions that actually matter."
>
  <div class="blog-index">
    <header class="blog-index__header">
      <h1 class="blog-index__title">Blog</h1>
      <p class="blog-index__sub">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} on AI architecture, systems thinking, and design.
      </p>
    </header>

    {page1Posts.length === 0 ? (
      <p class="blog-index__empty">No posts yet — check back soon.</p>
    ) : (
      <ol class="blog-index__list">
        {page1Posts.map((post) => (
          <li>
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
            />
          </li>
        ))}
      </ol>
    )}

    {hasMore && (
      <p class="blog-index__more">
        Showing {PAGE_SIZE} of {posts.length} posts.
      </p>
    )}
  </div>
</BaseLayout>

<style>
  .blog-index {
    max-width: 64rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }
  .blog-index__header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .blog-index__title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
  }
  .blog-index__sub {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .blog-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .blog-index__empty,
  .blog-index__more {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-top: 2rem;
  }
</style>
