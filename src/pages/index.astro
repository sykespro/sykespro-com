---
import { getCollection } from 'astro:content';
import BlogCard from '../components/BlogCard.astro';
import CallToAction from '../components/CallToAction.astro';
import HeroSection from '../components/HeroSection.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

  <HeroSection />

  {recentPosts.length > 0 && (
    <section class="recent-posts">
      <div class="recent-posts__inner">
        <h2 class="recent-posts__heading">Recent writing</h2>
        <div class="recent-posts__grid">
          {recentPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id}
            />
          ))}
        </div>
        <a href="/blog" class="recent-posts__all">View all posts &rarr;</a>
      </div>
    </section>
  )}

  <section class="home-cta">
    <div class="home-cta__inner">
      <CallToAction
        heading="Working on something hard? Let's talk."
        body="I take a small number of advisory engagements each year. If you're navigating a difficult AI or systems architecture decision, I'm happy to think through it with you."
        ctaText="Get in touch"
        ctaHref="/contact"
      />
    </div>
  </section>

</BaseLayout>

<style>
  .recent-posts {
    padding: 4rem 1.5rem 2rem;
  }
  .recent-posts__inner {
    max-width: 64rem;
    margin: 0 auto;
  }
  .recent-posts__heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin: 0 0 1.75rem;
  }
  .recent-posts__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(22rem, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .recent-posts__all {
    display: inline-block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .recent-posts__all:hover {
    color: var(--color-primary-hover);
  }
  .home-cta {
    padding: 2rem 1.5rem 4rem;
  }
  .home-cta__inner {
    max-width: 64rem;
    margin: 0 auto;
  }
</style>
